# Copy to .env (gitignored). Never commit real values.

# --- Core (local dev + deploy) ---
ANAMNESIS_DASHSCOPE_API_KEY=
ANAMNESIS_HELIUS_API_KEY=
ANAMNESIS_MONGODB_URI=          # local dev only; the docker-compose deploy overrides this
ANAMNESIS_DB=anamnesis
QWEN_MODEL=qwen-max

# --- Deploy (docker-compose / Alibaba ECS — see deploy/RUNBOOK.md) ---
# Self-hosted Mongo: compose creates this root user and builds the app's connection URI from it.
# Use an ALPHANUMERIC password — URI-reserved chars (@ : / # ?) break the mongodb:// string.
MONGO_USER=anamnesis
MONGO_PASSWORD=
# Public base URL for cluster-graph links (must match the nginx /graphs/ location).
ANAMNESIS_GRAPHS_BASE_URL=https://anamnesis.your-domain/graphs
