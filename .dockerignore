# Keep the image lean + the build context small. The build needs pyproject.toml, src/, mcp/,
# scripts/, api/ and frontend/ (the node stage builds frontend/dist fresh inside the image).
# Everything else — including the committed frontend/dist and node_modules — is excluded.
.git
.github
.venv
**/__pycache__
*.pyc
.pytest_cache
.ruff_cache
*.egg-info
graphs/
.env
.env.*
!.env.example
frontend/node_modules
frontend/dist
assets
docs
tests
deploy
*.md
